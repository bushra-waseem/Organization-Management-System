@model Dapper_Company.Models.Department
@{
    Layout = null;
}

<div class="modern-form-container-pink">
    <div class="form-header-pink edit-header-pink">
        <div class="header-icon-pink">
            <i class="bi bi-pencil-square"></i>
        </div>
        <h2>Edit Department</h2>
        <p class="form-subtitle-pink">Update department information</p>
    </div>

    <form id="dept-edit-form" class="modern-form-pink">
        @Html.AntiForgeryToken()
        <input type="hidden" name="Id" value="@Model.Id" />

        <div class="form-group-pink">
            <label class="modern-label-pink">
                <i class="bi bi-diagram-3"></i>
                Department Name
                <span class="required-pink">*</span>
            </label>
            <input name="Name"
                   class="modern-input-pink"
                   value="@Model.Name"
                   placeholder="Enter department name"
                   required />
            <span class="input-helper-pink">Update the name of the department</span>
        </div>

        <div class="form-group-pink">
            <label class="modern-label-pink">
                <i class="bi bi-building"></i>
                Organization
                <span class="required-pink">*</span>
            </label>
            <select name="OrganizationId" class="modern-select-pink" required>
                <option value="">Select an organization</option>
                @foreach (var org in ViewBag.Organizations)
                {
                    <option value="@org.Id"
                            selected="@(org.Id == Model.OrganizationId)">
                        @org.Name
                    </option>
                }
            </select>
            <span class="input-helper-pink">Change the organization if needed</span>
        </div>

        <div class="form-info-pink">
            <div class="info-icon-pink">
                <i class="bi bi-info-circle-fill"></i>
            </div>
            <div>
                <p class="info-title-pink">Department ID: <strong>#@Model.Id</strong></p>
                <p class="info-text-pink">This is your unique department identifier</p>
            </div>
        </div>

        <div class="form-actions-pink">
            <button type="button"
                    class="btn-secondary-pink"
                    onclick="refreshDepartmentTable()">
                <i class="bi bi-x-circle"></i>
                Cancel
            </button>
            <button type="submit" class="btn-primary-pink">
                <i class="bi bi-check-circle-fill"></i>
                Update Department
            </button>
        </div>
    </form>
</div>

<style>
    .modern-form-container-pink {
        max-width: 650px;
        margin: 0 auto;
        background: #ffffff;
        border-radius: 30px;
        box-shadow: 0 20px 60px rgba(255, 152, 0, 0.25);
        overflow: hidden;
        border: 3px solid rgba(255, 152, 0, 0.2);
        animation: slideIn 0.4s ease;
    }

    @@keyframes slideIn {
        from {
            opacity: 0;
            transform: translateY(-20px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .form-header-pink {
        color: white;
        padding: 45px 40px;
        text-align: center;
        position: relative;
        overflow: hidden;
    }

    .edit-header-pink {
        background: linear-gradient(135deg, #ffb347 0%, #ff9800 100%);
    }

        .edit-header-pink::before {
            content: '';
            position: absolute;
            top: -50%;
            right: -50%;
            width: 200%;
            height: 200%;
            background: radial-gradient(circle, rgba(255, 255, 255, 0.1) 0%, transparent 70%);
            animation: rotate 15s linear infinite;
        }

    @@keyframes rotate {
        from {
            transform: rotate(0deg);
        }

        to {
            transform: rotate(360deg);
        }
    }

    .header-icon-pink {
        width: 70px;
        height: 70px;
        background: rgba(255, 255, 255, 0.2);
        backdrop-filter: blur(10px);
        border-radius: 20px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 20px;
        font-size: 32px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
        border: 3px solid rgba(255, 255, 255, 0.3);
        position: relative;
        z-index: 1;
    }

    .form-header-pink h2 {
        margin: 0 0 12px 0;
        font-size: 32px;
        font-weight: 900;
        text-shadow: 0 4px 15px rgba(0, 0, 0, 0.2);
        position: relative;
        z-index: 1;
    }

    .form-subtitle-pink {
        margin: 0;
        opacity: 0.95;
        font-size: 16px;
        font-weight: 500;
        position: relative;
        z-index: 1;
    }

    .modern-form-pink {
        padding: 45px 40px;
    }

    .form-group-pink {
        margin-bottom: 30px;
    }

    .modern-label-pink {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 15px;
        font-weight: 700;
        color: #2c2c2c;
        margin-bottom: 12px;
    }

        .modern-label-pink i {
            color: #ff9800;
            font-size: 18px;
        }

    .required-pink {
        color: #dc2626;
        margin-left: 4px;
        font-size: 18px;
    }

    .modern-input-pink,
    .modern-select-pink {
        width: 100%;
        padding: 16px 20px;
        border: 3px solid rgba(255, 152, 0, 0.2);
        border-radius: 15px;
        font-size: 15px;
        transition: all 0.3s ease;
        background: #fff9f0;
        font-weight: 500;
        color: #2c2c2c;
    }

        .modern-input-pink:focus,
        .modern-select-pink:focus {
            outline: none;
            border-color: #ff9800;
            box-shadow: 0 0 0 4px rgba(255, 152, 0, 0.1);
            background: white;
        }

        .modern-input-pink::placeholder {
            color: #a0a0a0;
            font-weight: 400;
        }

    .modern-select-pink {
        cursor: pointer;
        appearance: none;
        background-image: url("data:image/svg+xml,%3Csvg width='14' height='8' viewBox='0 0 14 8' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M1 1L7 7L13 1' stroke='%23ff9800' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'/%3E%3C/svg%3E");
        background-repeat: no-repeat;
        background-position: right 20px center;
        padding-right: 50px;
    }

    .input-helper-pink {
        display: block;
        margin-top: 8px;
        font-size: 13px;
        color: #6a6a6a;
        font-style: italic;
    }

    .form-info-pink {
        background: linear-gradient(135deg, #fff9f0 0%, #ffedd5 100%);
        border: 3px solid rgba(255, 152, 0, 0.2);
        border-radius: 20px;
        padding: 20px 25px;
        display: flex;
        gap: 18px;
        margin-bottom: 35px;
        box-shadow: 0 4px 15px rgba(255, 152, 0, 0.1);
    }

    .info-icon-pink {
        flex-shrink: 0;
        width: 50px;
        height: 50px;
        background: linear-gradient(135deg, #ffb347 0%, #ff9800 100%);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-size: 24px;
        box-shadow: 0 6px 18px rgba(255, 152, 0, 0.3);
    }

    .info-title-pink {
        font-weight: 700;
        color: #2c2c2c;
        margin: 0 0 6px 0;
        font-size: 16px;
    }

        .info-title-pink strong {
            color: #ff9800;
            background: rgba(255, 152, 0, 0.15);
            padding: 2px 8px;
            border-radius: 6px;
            font-family: 'Courier New', monospace;
        }

    .info-text-pink {
        color: #6a6a6a;
        margin: 0;
        font-size: 14px;
        font-weight: 500;
    }

    .form-actions-pink {
        display: flex;
        gap: 15px;
        justify-content: flex-end;
        margin-top: 40px;
        padding-top: 30px;
        border-top: 3px solid rgba(255, 152, 0, 0.1);
    }

    .btn-primary-pink,
    .btn-secondary-pink {
        padding: 16px 32px;
        border-radius: 50px;
        font-size: 15px;
        font-weight: 700;
        border: none;
        cursor: pointer;
        transition: all 0.3s ease;
        display: flex;
        align-items: center;
        gap: 10px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

        .btn-primary-pink i,
        .btn-secondary-pink i {
            font-size: 18px;
        }

    .btn-primary-pink {
        background: linear-gradient(135deg, #ffb347 0%, #ff9800 100%);
        color: white;
        box-shadow: 0 8px 25px rgba(255, 152, 0, 0.3);
    }

        .btn-primary-pink:hover {
            transform: translateY(-3px);
            box-shadow: 0 12px 35px rgba(255, 152, 0, 0.4);
        }

    .btn-secondary-pink {
        background: linear-gradient(135deg, rgba(255, 152, 0, 0.1) 0%, rgba(255, 179, 71, 0.1) 100%);
        color: #ff9800;
        border: 2px solid rgba(255, 152, 0, 0.3);
    }

        .btn-secondary-pink:hover {
            background: linear-gradient(135deg, rgba(255, 152, 0, 0.2) 0%, rgba(255, 179, 71, 0.2) 100%);
            transform: translateY(-2px);
        }

    @@media (max-width: 768px) {
        .modern-form-container-pink {
            border-radius: 20px;
            margin: 10px;
        }

        .form-header-pink {
            padding: 35px 25px;
        }

            .form-header-pink h2 {
                font-size: 26px;
            }

        .modern-form-pink {
            padding: 30px 25px;
        }

        .form-info-pink {
            flex-direction: column;
            text-align: center;
        }

        .info-icon-pink {
            margin: 0 auto;
        }

        .form-actions-pink {
            flex-direction: column;
        }

        .btn-primary-pink,
        .btn-secondary-pink {
            width: 100%;
            justify-content: center;
        }
    }
</style>