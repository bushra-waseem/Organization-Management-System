@model Dapper_Company.Models.Organization
@{
    Layout = null;
}

<div class="modern-form-container-pink">
    <div class="form-header-pink delete-header-pink">
        <div class="header-icon-pink">
            <i class="bi bi-exclamation-triangle-fill"></i>
        </div>
        <h2>Delete Organization</h2>
        <p class="form-subtitle-pink">This action cannot be undone</p>
    </div>

    <div class="modern-form-pink">
        <div class="warning-box-pink">
            <div class="warning-icon-pink">
                <i class="bi bi-shield-fill-exclamation"></i>
            </div>
            <div>
                <p class="warning-title-pink">Are you sure you want to delete this organization?</p>
                <p class="warning-message-pink">
                    You are about to permanently delete <strong>@Model.Name</strong>.
                    This action cannot be undone and all associated data will be lost.
                </p>
            </div>
        </div>

        <form id="org-delete-form">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" value="@Model.Id" />

            <div class="form-actions-pink">
                <button type="button"
                        class="btn-secondary-pink"
                        onclick="refreshOrgTable()">
                    <i class="bi bi-x-circle"></i>
                    Cancel
                </button>
                <button type="submit" class="btn-danger-pink">
                    <i class="bi bi-trash-fill"></i>
                    Delete Organization
                </button>
            </div>
        </form>

        <div id="org-delete-error" class="error-alert-pink" style="display:none;"></div>

        @if (ViewBag.ErrorMessage != null)
        {
            <div class="error-alert-pink">
                <i class="bi bi-x-octagon-fill"></i>
                @ViewBag.ErrorMessage
            </div>
        }
    </div>
</div>

<style>
    .modern-form-container-pink {
        max-width: 650px;
        margin: 0 auto;
        background: #ffffff;
        border-radius: 30px;
        box-shadow: 0 20px 60px rgba(220, 38, 38, 0.25);
        overflow: hidden;
        border: 3px solid rgba(220, 38, 38, 0.2);
        animation: slideIn 0.4s ease;
    }

    @@keyframes slideIn {
        from {
            opacity: 0;
            transform: translateY(-20px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .form-header-pink {
        color: white;
        padding: 45px 40px;
        text-align: center;
        position: relative;
        overflow: hidden;
    }

    .delete-header-pink {
        background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%);
    }

        .delete-header-pink::before {
            content: '';
            position: absolute;
            top: -50%;
            right: -50%;
            width: 200%;
            height: 200%;
            background: radial-gradient(circle, rgba(255, 255, 255, 0.1) 0%, transparent 70%);
            animation: rotate 15s linear infinite;
        }

    @@keyframes rotate {
        from {
            transform: rotate(0deg);
        }

        to {
            transform: rotate(360deg);
        }
    }

    .header-icon-pink {
        width: 70px;
        height: 70px;
        background: rgba(255, 255, 255, 0.2);
        backdrop-filter: blur(10px);
        border-radius: 20px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 20px;
        font-size: 32px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
        border: 3px solid rgba(255, 255, 255, 0.3);
        position: relative;
        z-index: 1;
        animation: shake 2s infinite;
    }

    @@keyframes shake {
        0%, 100% {
            transform: rotate(0deg);
        }

        25% {
            transform: rotate(-5deg);
        }

        75% {
            transform: rotate(5deg);
        }
    }

    .form-header-pink h2 {
        margin: 0 0 12px 0;
        font-size: 32px;
        font-weight: 900;
        text-shadow: 0 4px 15px rgba(0, 0, 0, 0.2);
        position: relative;
        z-index: 1;
    }

    .form-subtitle-pink {
        margin: 0;
        opacity: 0.95;
        font-size: 16px;
        font-weight: 500;
        position: relative;
        z-index: 1;
    }

    .modern-form-pink {
        padding: 45px 40px;
    }

    .warning-box-pink {
        background: linear-gradient(135deg, #fef2f2 0%, #fee2e2 100%);
        border: 3px solid #fecaca;
        border-radius: 20px;
        padding: 25px;
        display: flex;
        gap: 20px;
        margin-bottom: 30px;
        box-shadow: 0 8px 25px rgba(220, 38, 38, 0.15);
    }

    .warning-icon-pink {
        flex-shrink: 0;
        width: 55px;
        height: 55px;
        background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-size: 28px;
        box-shadow: 0 8px 20px rgba(220, 38, 38, 0.3);
    }

    .warning-title-pink {
        font-weight: 800;
        color: #991b1b;
        margin: 0 0 12px 0;
        font-size: 18px;
    }

    .warning-message-pink {
        color: #7f1d1d;
        margin: 0;
        font-size: 15px;
        line-height: 1.6;
        font-weight: 500;
    }

        .warning-message-pink strong {
            color: #991b1b;
            font-weight: 800;
            background: rgba(220, 38, 38, 0.1);
            padding: 2px 6px;
            border-radius: 5px;
        }

    .form-actions-pink {
        display: flex;
        gap: 15px;
        justify-content: flex-end;
        margin-top: 35px;
        padding-top: 30px;
        border-top: 3px solid rgba(220, 38, 38, 0.1);
    }

    .btn-danger-pink,
    .btn-secondary-pink {
        padding: 16px 32px;
        border-radius: 50px;
        font-size: 15px;
        font-weight: 700;
        border: none;
        cursor: pointer;
        transition: all 0.3s ease;
        display: flex;
        align-items: center;
        gap: 10px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

        .btn-danger-pink i,
        .btn-secondary-pink i {
            font-size: 18px;
        }

    .btn-danger-pink {
        background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%);
        color: white;
        box-shadow: 0 8px 25px rgba(220, 38, 38, 0.3);
    }

        .btn-danger-pink:hover {
            transform: translateY(-3px);
            box-shadow: 0 12px 35px rgba(220, 38, 38, 0.4);
        }

    .btn-secondary-pink {
        background: linear-gradient(135deg, rgba(220, 38, 38, 0.1) 0%, rgba(239, 68, 68, 0.1) 100%);
        color: #dc2626;
        border: 2px solid rgba(220, 38, 38, 0.3);
    }

        .btn-secondary-pink:hover {
            background: linear-gradient(135deg, rgba(220, 38, 38, 0.2) 0%, rgba(239, 68, 68, 0.2) 100%);
            transform: translateY(-2px);
        }

    .error-alert-pink {
        background: linear-gradient(135deg, #fef2f2 0%, #fee2e2 100%);
        border: 2px solid #fecaca;
        color: #991b1b;
        padding: 20px 25px;
        border-radius: 15px;
        margin-top: 20px;
        display: flex;
        align-items: center;
        gap: 15px;
        font-size: 15px;
        font-weight: 600;
        box-shadow: 0 4px 15px rgba(220, 38, 38, 0.15);
    }

        .error-alert-pink i {
            font-size: 24px;
            flex-shrink: 0;
        }

    @@media (max-width: 768px) {
        .modern-form-container-pink {
            border-radius: 20px;
            margin: 10px;
        }

        .form-header-pink {
            padding: 35px 25px;
        }

            .form-header-pink h2 {
                font-size: 26px;
            }

        .modern-form-pink {
            padding: 30px 25px;
        }

        .warning-box-pink {
            flex-direction: column;
            text-align: center;
        }

        .warning-icon-pink {
            margin: 0 auto;
        }

        .form-actions-pink {
            flex-direction: column;
        }

        .btn-danger-pink,
        .btn-secondary-pink {
            width: 100%;
            justify-content: center;
        }
    }
</style>