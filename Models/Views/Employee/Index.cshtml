@model IEnumerable<Dapper_Company.Models.Employee>
@{
    Layout = null;
}

<div class="employees-container-pink">
    <div class="header-section-pink">
        <div class="header-content-pink">
            <button class="btn-create-pink" onclick="showEmployeeCreate()">
                <i class="bi bi-plus-circle-fill"></i>
                Create Employee
            </button>
        </div>
    </div>

    <div class="table-container-pink">
        <table class="data-table-pink">
            <thead>
                <tr>
                    <th class="col-id">ID</th>
                    <th class="col-name">Name</th>
                    <th class="col-gender">Gender</th>
                    <th class="col-salary">Salary</th>
                    <th class="col-org">Organization</th>
                    <th class="col-dept">Department</th>
                    <th class="col-position">Position</th>
                    <th class="col-actions">Actions</th>
                </tr>
            </thead>
            <tbody>
                @{
                    int displayId = 1;
                }
                @foreach (var emp in Model)
                {
                    <tr>
                        <td class="cell-id">
                            <span class="id-tag-pink">#@emp.Id</span>
                        </td>
                        <td class="cell-name">
                            <div class="emp-info-pink">
                                <div class="emp-icon-pink">
                                    <i class="bi bi-person-fill"></i>
                                </div>
                                <span class="emp-name-pink">@emp.Name</span>
                            </div>
                        </td>
                        <td class="cell-gender">
                            <span class="gender-badge-pink">
                                <i class="bi bi-gender-ambiguous"></i>
                                @emp.Gender
                            </span>
                        </td>
                        <td class="cell-salary">
                            <span class="salary-text-pink">
                                <i class="bi bi-cash-stack"></i>
                                $@emp.Salary
                            </span>
                        </td>
                        <td class="cell-org">
                            <span class="org-tag-pink">
                                <i class="bi bi-building"></i>
                                @emp.OrganizationName
                            </span>
                        </td>
                        <td class="cell-dept">
                            <span class="dept-tag-pink">
                                <i class="bi bi-diagram-3"></i>
                                @emp.DepartmentName
                            </span>
                        </td>
                        <td class="cell-position">
                            <span class="position-tag-pink">
                                <i class="bi bi-award"></i>
                                @emp.PositionName
                            </span>
                        </td>
                        <td class="cell-actions">
                            <div class="action-buttons-pink">
                                <button class="btn-action-pink btn-edit-pink"
                                        onclick="loadEmployeeEdit(@emp.Id)"
                                        title="Edit">
                                    <i class="bi bi-pencil-fill"></i>
                                </button>

                                <button class="btn-action-pink btn-delete-pink"
                                        onclick="loadEmployeeDelete(@emp.Id)"
                                        title="Delete">
                                    <i class="bi bi-trash-fill"></i>
                                </button>
                            </div>
                        </td>
                    </tr>
                    displayId++;
                }
            </tbody>
        </table>
    </div>
</div>

<style>
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    .employees-container-pink {
        padding: 40px;
        background: linear-gradient(135deg, #fef5f8 0%, #ffe5ed 100%);
        border-radius: 30px;
        margin-bottom: 40px;
    }

    .header-section-pink {
        margin-bottom: 35px;
        padding-bottom: 25px;
        border-bottom: 3px solid rgba(255, 105, 135, 0.2);
    }

    .header-content-pink {
        display: flex;
        justify-content: flex-end;
    }

    .btn-create-pink {
        display: inline-flex;
        align-items: center;
        gap: 12px;
        padding: 16px 32px;
        background: linear-gradient(135deg, #ff6987 0%, #d84a64 100%);
        color: white;
        border: none;
        border-radius: 50px;
        font-size: 16px;
        font-weight: 700;
        cursor: pointer;
        transition: all 0.3s ease;
        box-shadow: 0 8px 25px rgba(255, 105, 135, 0.3);
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

        .btn-create-pink:hover {
            transform: translateY(-3px);
            box-shadow: 0 12px 35px rgba(255, 105, 135, 0.4);
        }

        .btn-create-pink i {
            font-size: 20px;
        }

    .table-container-pink {
        background: white;
        border-radius: 25px;
        box-shadow: 0 15px 50px rgba(255, 105, 135, 0.15);
        overflow-x: auto;
        border: 3px solid rgba(255, 105, 135, 0.1);
    }

    .data-table-pink {
        width: 100%;
        border-collapse: collapse;
        min-width: 1200px;
    }

        .data-table-pink thead {
            background: linear-gradient(135deg, rgba(255, 105, 135, 0.1) 0%, rgba(255, 179, 193, 0.1) 100%);
            border-bottom: 3px solid rgba(255, 105, 135, 0.2);
        }

        .data-table-pink th {
            padding: 20px 20px;
            text-align: left;
            font-size: 12px;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: #ff6987;
            white-space: nowrap;
        }

    .col-id {
        width: 90px;
    }

    .col-gender {
        width: 130px;
    }

    .col-salary {
        width: 140px;
    }

    .col-org {
        width: 160px;
    }

    .col-dept {
        width: 150px;
    }

    .col-position {
        width: 140px;
    }

    .col-actions {
        width: 130px;
        text-align: center;
    }

    .data-table-pink tbody tr {
        border-bottom: 2px solid rgba(255, 105, 135, 0.08);
        transition: all 0.3s ease;
    }

        .data-table-pink tbody tr:last-child {
            border-bottom: none;
        }

        .data-table-pink tbody tr:hover {
            background: linear-gradient(135deg, rgba(255, 105, 135, 0.05) 0%, rgba(255, 179, 193, 0.05) 100%);
            transform: scale(1.005);
        }

    .data-table-pink td {
        padding: 18px 20px;
        font-size: 14px;
        color: #2c2c2c;
    }

    .cell-id {
        font-weight: 600;
    }

    .id-tag-pink {
        display: inline-block;
        padding: 7px 16px;
        background: linear-gradient(135deg, rgba(255, 105, 135, 0.15) 0%, rgba(255, 179, 193, 0.15) 100%);
        color: #ff6987;
        border-radius: 50px;
        font-size: 13px;
        font-weight: 700;
        font-family: 'Courier New', monospace;
        border: 2px solid rgba(255, 105, 135, 0.2);
    }

    .emp-info-pink {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .emp-icon-pink {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        background: linear-gradient(135deg, #ff6987 0%, #d84a64 100%);
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-size: 18px;
        box-shadow: 0 6px 15px rgba(255, 105, 135, 0.3);
        flex-shrink: 0;
    }

    .emp-name-pink {
        font-weight: 700;
        color: #2c2c2c;
        font-size: 15px;
    }

    .gender-badge-pink {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 8px 16px;
        background: linear-gradient(135deg, rgba(59, 130, 246, 0.15) 0%, rgba(147, 197, 253, 0.15) 100%);
        color: #1e40af;
        border-radius: 50px;
        font-size: 13px;
        font-weight: 600;
        border: 2px solid rgba(59, 130, 246, 0.2);
    }

        .gender-badge-pink i {
            font-size: 14px;
        }

    .salary-text-pink {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        font-weight: 700;
        color: #059669;
        font-size: 15px;
    }

        .salary-text-pink i {
            font-size: 16px;
        }

    .org-tag-pink {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 7px 14px;
        background: linear-gradient(135deg, rgba(102, 126, 234, 0.15) 0%, rgba(118, 75, 162, 0.15) 100%);
        color: #667eea;
        border-radius: 50px;
        font-size: 12px;
        font-weight: 600;
        border: 2px solid rgba(102, 126, 234, 0.2);
    }

        .org-tag-pink i {
            font-size: 13px;
        }

    .dept-tag-pink {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 7px 14px;
        background: linear-gradient(135deg, rgba(139, 92, 246, 0.15) 0%, rgba(167, 139, 250, 0.15) 100%);
        color: #7c3aed;
        border-radius: 50px;
        font-size: 12px;
        font-weight: 600;
        border: 2px solid rgba(139, 92, 246, 0.2);
    }

        .dept-tag-pink i {
            font-size: 13px;
        }

    .position-tag-pink {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 7px 14px;
        background: linear-gradient(135deg, rgba(251, 191, 36, 0.15) 0%, rgba(252, 211, 77, 0.15) 100%);
        color: #92400e;
        border-radius: 50px;
        font-size: 12px;
        font-weight: 600;
        border: 2px solid rgba(251, 191, 36, 0.2);
    }

        .position-tag-pink i {
            font-size: 13px;
        }

    .cell-actions {
        text-align: center;
    }

    .action-buttons-pink {
        display: flex;
        justify-content: center;
        gap: 10px;
    }

    .btn-action-pink {
        width: 42px;
        height: 42px;
        display: flex;
        align-items: center;
        justify-content: center;
        border: none;
        border-radius: 50%;
        cursor: pointer;
        transition: all 0.3s ease;
        font-size: 15px;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
    }

    .btn-edit-pink {
        background: linear-gradient(135deg, rgba(255, 179, 71, 0.2) 0%, rgba(255, 152, 0, 0.2) 100%);
        color: #ff9800;
        border: 2px solid rgba(255, 152, 0, 0.3);
    }

        .btn-edit-pink:hover {
            background: linear-gradient(135deg, #ffb347 0%, #ff9800 100%);
            color: white;
            transform: translateY(-3px) rotate(360deg);
            box-shadow: 0 8px 25px rgba(255, 152, 0, 0.4);
        }

    .btn-delete-pink {
        background: linear-gradient(135deg, rgba(239, 68, 68, 0.2) 0%, rgba(220, 38, 38, 0.2) 100%);
        color: #dc2626;
        border: 2px solid rgba(220, 38, 38, 0.3);
    }

        .btn-delete-pink:hover {
            background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%);
            color: white;
            transform: translateY(-3px) scale(1.1);
            box-shadow: 0 8px 25px rgba(220, 38, 38, 0.4);
        }

    @@media (max-width: 768px) {
        .employees-container-pink {
            padding: 20px;
            border-radius: 20px;
        }

        .btn-create-pink {
            width: 100%;
            justify-content: center;
            padding: 14px 24px;
        }

        .table-container-pink {
            overflow-x: auto;
        }

        .emp-icon-pink {
            width: 35px;
            height: 35px;
            font-size: 16px;
        }

        .btn-action-pink {
            width: 38px;
            height: 38px;
            font-size: 14px;
        }
    }
</style>