@model Dapper_Company.Models.Organization
@{
    Layout = null;
}

<div class="modern-form-container-pink">
    <div class="form-header-pink">
        <div class="header-icon-pink">
            <i class="bi bi-building-fill-add"></i>
        </div>
        <h2>Create New Organization</h2>
        <p class="form-subtitle-pink">Add a new organization to your management system</p>
    </div>

    <form id="org-create-form" class="modern-form-pink">
        @Html.AntiForgeryToken()

        <div class="form-group-pink">
            <label class="modern-label-pink">
                <i class="bi bi-building"></i>
                Organization Name
                <span class="required-pink">*</span>
            </label>
            <input name="Name"
                   class="modern-input-pink"
                   placeholder="e.g., Acme Corporation"
                   required />
            <span class="input-helper-pink">Enter a unique name for your organization</span>
        </div>

        <div class="form-actions-pink">
            <button type="button"
                    class="btn-secondary-pink"
                    onclick="refreshOrgTable()">
                <i class="bi bi-x-circle"></i>
                Cancel
            </button>
            <button type="submit" class="btn-primary-pink">
                <i class="bi bi-check-circle-fill"></i>
                Create Organization
            </button>
        </div>
    </form>
</div>

<style>
    .modern-form-container-pink {
        max-width: 650px;
        margin: 0 auto;
        background: #ffffff;
        border-radius: 30px;
        box-shadow: 0 20px 60px rgba(255, 105, 135, 0.25);
        overflow: hidden;
        border: 3px solid rgba(255, 105, 135, 0.1);
        animation: slideIn 0.4s ease;
    }

    @@keyframes slideIn {
        from {
            opacity: 0;
            transform: translateY(-20px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .form-header-pink {
        background: linear-gradient(135deg, #ff6987 0%, #d84a64 100%);
        color: white;
        padding: 45px 40px;
        text-align: center;
        position: relative;
        overflow: hidden;
    }

        .form-header-pink::before {
            content: '';
            position: absolute;
            top: -50%;
            right: -50%;
            width: 200%;
            height: 200%;
            background: radial-gradient(circle, rgba(255, 255, 255, 0.1) 0%, transparent 70%);
            animation: rotate 15s linear infinite;
        }

    @@keyframes rotate {
        from {
            transform: rotate(0deg);
        }

        to {
            transform: rotate(360deg);
        }
    }

    .header-icon-pink {
        width: 70px;
        height: 70px;
        background: rgba(255, 255, 255, 0.2);
        backdrop-filter: blur(10px);
        border-radius: 20px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 20px;
        font-size: 32px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
        border: 3px solid rgba(255, 255, 255, 0.3);
        position: relative;
        z-index: 1;
    }

    .form-header-pink h2 {
        margin: 0 0 12px 0;
        font-size: 32px;
        font-weight: 900;
        text-shadow: 0 4px 15px rgba(0, 0, 0, 0.2);
        position: relative;
        z-index: 1;
    }

    .form-subtitle-pink {
        margin: 0;
        opacity: 0.95;
        font-size: 16px;
        font-weight: 500;
        position: relative;
        z-index: 1;
    }

    .modern-form-pink {
        padding: 45px 40px;
    }

    .form-group-pink {
        margin-bottom: 30px;
    }

    .modern-label-pink {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 15px;
        font-weight: 700;
        color: #2c2c2c;
        margin-bottom: 12px;
    }

        .modern-label-pink i {
            color: #ff6987;
            font-size: 18px;
        }

    .required-pink {
        color: #dc2626;
        margin-left: 4px;
        font-size: 18px;
    }

    .modern-input-pink {
        width: 100%;
        padding: 16px 20px;
        border: 3px solid rgba(255, 105, 135, 0.2);
        border-radius: 15px;
        font-size: 15px;
        transition: all 0.3s ease;
        background: #fef5f8;
        font-weight: 500;
        color: #2c2c2c;
    }

        .modern-input-pink:focus {
            outline: none;
            border-color: #ff6987;
            box-shadow: 0 0 0 4px rgba(255, 105, 135, 0.1);
            background: white;
        }

        .modern-input-pink::placeholder {
            color: #a0a0a0;
            font-weight: 400;
        }

    .input-helper-pink {
        display: block;
        margin-top: 8px;
        font-size: 13px;
        color: #6a6a6a;
        font-style: italic;
    }

    .form-actions-pink {
        display: flex;
        gap: 15px;
        justify-content: flex-end;
        margin-top: 40px;
        padding-top: 30px;
        border-top: 3px solid rgba(255, 105, 135, 0.1);
    }

    .btn-primary-pink,
    .btn-secondary-pink {
        padding: 16px 32px;
        border-radius: 50px;
        font-size: 15px;
        font-weight: 700;
        border: none;
        cursor: pointer;
        transition: all 0.3s ease;
        display: flex;
        align-items: center;
        gap: 10px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

        .btn-primary-pink i,
        .btn-secondary-pink i {
            font-size: 18px;
        }

    .btn-primary-pink {
        background: linear-gradient(135deg, #ff6987 0%, #d84a64 100%);
        color: white;
        box-shadow: 0 8px 25px rgba(255, 105, 135, 0.3);
    }

        .btn-primary-pink:hover {
            transform: translateY(-3px);
            box-shadow: 0 12px 35px rgba(255, 105, 135, 0.4);
        }

    .btn-secondary-pink {
        background: linear-gradient(135deg, rgba(255, 105, 135, 0.1) 0%, rgba(255, 179, 193, 0.1) 100%);
        color: #ff6987;
        border: 2px solid rgba(255, 105, 135, 0.3);
    }

        .btn-secondary-pink:hover {
            background: linear-gradient(135deg, rgba(255, 105, 135, 0.2) 0%, rgba(255, 179, 193, 0.2) 100%);
            transform: translateY(-2px);
        }

    @@media (max-width: 768px) {
        .modern-form-container-pink {
            border-radius: 20px;
            margin: 10px;
        }

        .form-header-pink {
            padding: 35px 25px;
        }

            .form-header-pink h2 {
                font-size: 26px;
            }

        .modern-form-pink {
            padding: 30px 25px;
        }

        .form-actions-pink {
            flex-direction: column;
        }

        .btn-primary-pink,
        .btn-secondary-pink {
            width: 100%;
            justify-content: center;
        }
    }
</style>