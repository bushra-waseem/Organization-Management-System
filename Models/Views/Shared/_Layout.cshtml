<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - 𝒪𝓜𝒮</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" />
    <link rel="stylesheet" href="~/css/admin.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        html, body {
            margin: 0;
            padding: 0;
            height: 100%;
        }

        body {
            display: flex;
            flex-direction: column;
        }

        .hero-pink-section {
            min-height: auto;
        }

        footer {
            margin-top: auto;
        }


        body {
            font-family: 'Poppins', sans-serif;
            background: #fef5f8;
            color: #2c2c2c;
            overflow-x: hidden;
        }

        .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 20px;
        }

        /* MODERN NAVBAR */
        .navbar-modern {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            background: rgba(255, 255, 255, 0.98);
            backdrop-filter: blur(20px);
            padding: 15px 0;
            z-index: 1000;
            box-shadow: 0 4px 30px rgba(255, 105, 135, 0.15);
            border-bottom: 2px solid rgba(255, 105, 135, 0.1);
        }

        .navbar-content {
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .navbar-brand-modern {
            font-size: 36px;
            font-weight: 900;
            background: linear-gradient(135deg, #ff6987 0%, #d84a64 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            text-decoration: none;
            letter-spacing: -2px;
            text-shadow: 0 4px 10px rgba(255, 105, 135, 0.3);
            position: relative;
        }

            .navbar-brand-modern::before {
                content: '●';
                position: absolute;
                left: -15px;
                top: -5px;
                font-size: 12px;
                color: #ff6987;
                animation: pulse 2s infinite;
            }

        .navbar-menu-modern {
            display: flex;
            gap: 45px;
            list-style: none;
            align-items: center;
        }

            .navbar-menu-modern li a {
                color: #5a5a5a;
                text-decoration: none;
                font-weight: 600;
                font-size: 15px;
                transition: all 0.3s ease;
                position: relative;
                padding: 8px 0;
            }

                .navbar-menu-modern li a:hover,
                .navbar-menu-modern li a.active {
                    color: #ff6987;
                }

                .navbar-menu-modern li a::after {
                    content: '';
                    position: absolute;
                    bottom: 0;
                    left: 50%;
                    transform: translateX(-50%);
                    width: 0;
                    height: 3px;
                    background: linear-gradient(90deg, #ff6987, #d84a64);
                    border-radius: 10px;
                    transition: width 0.3s ease;
                }

                .navbar-menu-modern li a:hover::after,
                .navbar-menu-modern li a.active::after {
                    width: 100%;
                }

        /* DECORATIVE ELEMENTS */
        .decorative-blob {
            position: absolute;
            border-radius: 50%;
            filter: blur(80px);
            opacity: 0.3;
            animation: float 8s ease-in-out infinite;
            z-index: -1;
        }

        .blob-1 {
            width: 400px;
            height: 400px;
            background: linear-gradient(135deg, #ff6987 0%, #ffb3c1 100%);
            top: 10%;
            right: -200px;
        }

        .blob-2 {
            width: 500px;
            height: 500px;
            background: linear-gradient(135deg, #ffc4d0 0%, #ffe0e9 100%);
            bottom: -100px;
            left: -250px;
            animation-delay: 2s;
        }

        .blob-3 {
            width: 300px;
            height: 300px;
            background: linear-gradient(135deg, #d84a64 0%, #ff6987 100%);
            top: 50%;
            left: 50%;
            animation-delay: 4s;
        }

        @@keyframes float {
            0%, 100% { transform: translate(0, 0) rotate(0deg); }
            33% { transform: translate(30px, -30px) rotate(120deg); }
            66% { transform: translate(-20px, 20px) rotate(240deg); }
        }
         @@keyframes pulse {
            0%, 100% { opacity: 1; transform: scale(1); }
            50% { opacity: 0.5; transform: scale(1.2); }
        }

        

        /* TYPOGRAPHY ENHANCEMENTS */
        .gradient-text {
            background: linear-gradient(135deg, #ff6987 0%, #d84a64 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        /* BUTTON STYLES */
        .btn-pink-modern {
            background: linear-gradient(135deg, #ff6987 0%, #d84a64 100%);
            color: #fff;
            padding: 16px 40px;
            border-radius: 50px;
            text-decoration: none;
            font-weight: 700;
            transition: all 0.3s ease;
            box-shadow: 0 8px 30px rgba(255, 105, 135, 0.4);
            border: none;
            cursor: pointer;
            position: relative;
            overflow: hidden;
        }

            .btn-pink-modern::before {
                content: '';
                position: absolute;
                top: 0;
                left: -100%;
                width: 100%;
                height: 100%;
                background: linear-gradient(90deg, transparent, rgba(255,255,255,0.3), transparent);
                transition: left 0.5s ease;
            }

            .btn-pink-modern:hover::before {
                left: 100%;
            }

            .btn-pink-modern:hover {
                transform: translateY(-3px);
                box-shadow: 0 12px 40px rgba(255, 105, 135, 0.5);
            }

        .btn-outline-pink {
            background: transparent;
            color: #ff6987;
            padding: 16px 40px;
            border-radius: 50px;
            text-decoration: none;
            font-weight: 700;
            border: 3px solid #ff6987;
            transition: all 0.3s ease;
            position: relative;
            overflow: hidden;
        }

            .btn-outline-pink::before {
                content: '';
                position: absolute;
                top: 50%;
                left: 50%;
                width: 0;
                height: 0;
                background: linear-gradient(135deg, #ff6987 0%, #d84a64 100%);
                border-radius: 50%;
                transform: translate(-50%, -50%);
                transition: width 0.5s ease, height 0.5s ease;
                z-index: -1;
            }

            .btn-outline-pink:hover::before {
                width: 300px;
                height: 300px;
            }

            .btn-outline-pink:hover {
                color: #fff;
                border-color: #d84a64;
            }

        /* CARD STYLES */
        .modern-card {
            background: #fff;
            border-radius: 30px;
            padding: 40px;
            box-shadow: 0 15px 50px rgba(255, 105, 135, 0.15);
            transition: all 0.4s ease;
            border: 2px solid transparent;
            position: relative;
            overflow: hidden;
        }

            .modern-card::before {
                content: '';
                position: absolute;
                top: 0;
                left: 0;
                width: 100%;
                height: 4px;
                background: linear-gradient(90deg, #ff6987, #d84a64, #ff6987);
                background-size: 200% 100%;
                animation: shimmer 3s linear infinite;
            }
             @@keyframes shimmer {
            0% { background-position: -200% 0; }
            100% { background-position: 200% 0; }
        }
        

        .modern-card:hover {
            transform: translateY(-10px) scale(1.02);
            box-shadow: 0 25px 70px rgba(255, 105, 135, 0.25);
            border-color: rgba(255, 105, 135, 0.3);
        }

        /* FOOTER STYLES */
        .footer-modern {
            background: linear-gradient(135deg, #d84a64 0%, #a83750 100%);
            color: #fff;
            padding: 80px 0 30px;
            position: relative;
            overflow: hidden;
        }

            .footer-modern::before {
                content: '';
                position: absolute;
                top: 0;
                left: 0;
                right: 0;
                height: 5px;
                background: linear-gradient(90deg, #ff6987, #ffb3c1, #ff6987);
                background-size: 200% 100%;
                animation: shimmer 3s linear infinite;
            }

        .footer-grid {
            display: grid;
            grid-template-columns: 2fr 1fr 1fr 1.5fr;
            gap: 60px;
            margin-bottom: 0; /* ✅ important */
        }

        .footer-logo {
            font-size: 48px;
            font-weight: 900;
            margin-bottom: 20px;
            color: #fff;
            text-shadow: 0 4px 15px rgba(0,0,0,0.3);
            letter-spacing: -2px;
        }

        .footer-description {
            font-size: 15px;
            line-height: 1.8;
            color: rgba(255, 255, 255, 0.9);
            margin-bottom: 25px;
        }

        .social-footer {
            display: flex;
            gap: 15px;
        }

            .social-footer a {
                width: 50px;
                height: 50px;
                border-radius: 50%;
                background: rgba(255, 255, 255, 0.15);
                backdrop-filter: blur(10px);
                display: flex;
                align-items: center;
                justify-content: center;
                color: #fff;
                font-size: 20px;
                text-decoration: none;
                transition: all 0.3s ease;
                border: 2px solid rgba(255, 255, 255, 0.3);
            }

                .social-footer a:hover {
                    background: #fff;
                    color: #ff6987;
                    transform: translateY(-5px) rotate(360deg);
                    box-shadow: 0 10px 25px rgba(255, 255, 255, 0.3);
                }

        .footer-heading {
            font-size: 22px;
            font-weight: 700;
            margin-bottom: 25px;
            color: #fff;
            position: relative;
            padding-bottom: 12px;
        }

            .footer-heading::after {
                content: '';
                position: absolute;
                bottom: 0;
                left: 0;
                width: 50px;
                height: 4px;
                background: #fff;
                border-radius: 2px;
            }

        .footer-links {
            list-style: none;
        }

            .footer-links li {
                margin-bottom: 15px;
                font-size: 15px;
                color: rgba(255, 255, 255, 0.9);
                transition: all 0.3s ease;
            }

                .footer-links li:hover {
                    transform: translateX(8px);
                    color: #fff;
                }

            .footer-links a {
                color: rgba(255, 255, 255, 0.9);
                text-decoration: none;
                transition: all 0.3s ease;
                display: flex;
                align-items: center;
                gap: 8px;
            }

                .footer-links a:hover {
                    color: #fff;
                }

            .footer-links i {
                font-size: 18px;
                transition: transform 0.3s ease;
            }

            .footer-links li:hover i {
                transform: translateX(5px);
            }

        .contact-info-modern {
            display: flex;
            flex-direction: column;
            gap: 18px;
        }

        .contact-item {
            display: flex;
            align-items: center;
            gap: 15px;
            font-size: 15px;
            color: rgba(255, 255, 255, 0.9);
            transition: all 0.3s ease;
            padding: 12px;
            border-radius: 12px;
        }

            .contact-item:hover {
                background: rgba(255, 255, 255, 0.1);
                color: #fff;
            }

            .contact-item i {
                width: 45px;
                height: 45px;
                background: rgba(255, 255, 255, 0.2);
                border-radius: 12px;
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 20px;
                color: #fff;
                flex-shrink: 0;
            }


        .footer-bottom {
            margin-top: auto;
            text-align: center;
            padding-top: 30px;
            border-top: 1px solid rgba(255, 255, 255, 0.2);
            font-size: 15px;
            color: rgba(255, 255, 255, 0.8);
        }

            .footer-bottom i {
                color: #fff;
                animation: heartbeat 1.5s ease-in-out infinite;
            }
        @@keyframes heartbeat {
            0%, 100% {
                transform: scale(1);
            }

            25% {
                transform: scale(1.2);
            }

            50% {
                transform: scale(1);
            }
        }

        .footer-content {
            flex: 1; /* ✅ ye footer-bottom ko neeche push karega */
        }
        .footer-modern .container {
            display: flex;
            flex-direction: column;
            min-height: 100%;
        }

        /* RESPONSIVE */
        @@media (max-width: 768px) {
            .navbar-menu-modern {
                display: none;
            }

            .footer-grid {
                grid-template-columns: 1fr;
                gap: 40px;
            }
        }
    </style>
</head>

<body>
    <!-- Decorative Blobs -->
    <div class="decorative-blob blob-1"></div>
    <div class="decorative-blob blob-2"></div>
    <div class="decorative-blob blob-3"></div>


    <nav class="navbar-modern">
        <div class="container">
            <div class="navbar-content">
                <a href="#home" class="navbar-brand-modern">OMS</a>

                <ul class="navbar-menu-modern">
                    <li><a href="#home" class="active">Home</a></li>
                    <li><a href="#about">About</a></li>
                    <li><a href="#dashboard">Dashboard</a></li>
                    <li><a href="#contact">Contact</a></li>
                </ul>
            </div>
        </div>
    </nav>

    <div style="padding-top: 80px;">
        @RenderBody()
    </div>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js"></script>

    <script>
        // Smooth Scroll
        document.querySelectorAll('a[href^="#"]').forEach(anchor => {
            anchor.addEventListener('click', function (e) {
                e.preventDefault();
                const target = document.querySelector(this.getAttribute('href'));
                if (target) {
                    target.scrollIntoView({
                        behavior: 'smooth',
                        block: 'start'
                    });
                }
            });
        });

        // Active Menu on Scroll
        window.addEventListener('scroll', () => {
            const sections = document.querySelectorAll('section[id]');
            const scrollY = window.pageYOffset;

            sections.forEach(section => {
                const sectionHeight = section.offsetHeight;
                const sectionTop = section.offsetTop - 100;
                const sectionId = section.getAttribute('id');
                const navLink = document.querySelector(`.navbar-menu-modern a[href="#${sectionId}"]`);

                if (scrollY > sectionTop && scrollY <= sectionTop + sectionHeight) {
                    document.querySelectorAll('.navbar-menu-modern a').forEach(link => {
                        link.classList.remove('active');
                    });
                    if (navLink) {
                        navLink.classList.add('active');
                    }
                }
            });
        });
    </script>

    @RenderSection("Scripts", required: false)
</body>
</html>