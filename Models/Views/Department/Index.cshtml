@model IEnumerable<Dapper_Company.Models.Department>
@{
    Layout = null;
}

<div class="departments-container-pink">
    <div class="header-section-pink">
        <div class="header-content-pink">
            <button class="btn-create-pink" onclick="showDepartmentCreate()">
                <i class="bi bi-plus-circle-fill"></i>
                Create Department
            </button>
        </div>
    </div>

    <div class="table-container-pink">
        <table class="data-table-pink">
            <thead>
                <tr>
                    <th class="col-id">ID</th>
                    <th class="col-department">Department</th>
                    <th class="col-organization">Organization</th>
                    <th class="col-actions">Actions</th>
                </tr>
            </thead>
            <tbody>
                @{
                    int displayId = 1;
                }
                @foreach (var dept in Model)
                {
                    <tr>
                        <td class="cell-id">
                            <span class="id-tag-pink">#@dept.Id</span>
                        </td>
                        <td class="cell-department">
                            <div class="dept-info-pink">
                                <div class="dept-icon-pink">
                                    <i class="bi bi-diagram-3-fill"></i>
                                </div>
                                <span class="dept-name-pink">@dept.Name</span>
                            </div>
                        </td>
                        <td class="cell-organization">
                            <span class="org-tag-pink">
                                <i class="bi bi-building"></i>
                                @dept.OrganizationName
                            </span>
                        </td>
                        <td class="cell-actions">
                            <div class="action-buttons-pink">
                                <button class="btn-action-pink btn-edit-pink"
                                        onclick="loadDepartmentEdit(@dept.Id)"
                                        title="Edit">
                                    <i class="bi bi-pencil-fill"></i>
                                </button>
                                <button class="btn-action-pink btn-delete-pink"
                                        onclick="loadDepartmentDelete(@dept.Id)"
                                        title="Delete">
                                    <i class="bi bi-trash-fill"></i>
                                </button>
                            </div>
                        </td>
                    </tr>
                    displayId++;
                }
            </tbody>
        </table>
    </div>
</div>

<style>
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    .departments-container-pink {
        padding: 40px;
        background: linear-gradient(135deg, #fef5f8 0%, #ffe5ed 100%);
        border-radius: 30px;
        margin-bottom: 40px;
    }

    .header-section-pink {
        margin-bottom: 35px;
        padding-bottom: 25px;
        border-bottom: 3px solid rgba(255, 105, 135, 0.2);
    }

    .header-content-pink {
        display: flex;
        justify-content: flex-end;
    }

    .btn-create-pink {
        display: inline-flex;
        align-items: center;
        gap: 12px;
        padding: 16px 32px;
        background: linear-gradient(135deg, #ff6987 0%, #d84a64 100%);
        color: white;
        border: none;
        border-radius: 50px;
        font-size: 16px;
        font-weight: 700;
        cursor: pointer;
        transition: all 0.3s ease;
        box-shadow: 0 8px 25px rgba(255, 105, 135, 0.3);
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

        .btn-create-pink:hover {
            transform: translateY(-3px);
            box-shadow: 0 12px 35px rgba(255, 105, 135, 0.4);
        }

        .btn-create-pink i {
            font-size: 20px;
        }

    .table-container-pink {
        background: white;
        border-radius: 25px;
        box-shadow: 0 15px 50px rgba(255, 105, 135, 0.15);
        overflow: hidden;
        border: 3px solid rgba(255, 105, 135, 0.1);
    }

    .data-table-pink {
        width: 100%;
        border-collapse: collapse;
    }

        .data-table-pink thead {
            background: linear-gradient(135deg, rgba(255, 105, 135, 0.1) 0%, rgba(255, 179, 193, 0.1) 100%);
            border-bottom: 3px solid rgba(255, 105, 135, 0.2);
        }

        .data-table-pink th {
            padding: 20px 25px;
            text-align: left;
            font-size: 13px;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: #ff6987;
        }

    .col-id {
        width: 110px;
    }

    .col-organization {
        width: 200px;
    }

    .col-actions {
        width: 150px;
        text-align: center;
    }

    .data-table-pink tbody tr {
        border-bottom: 2px solid rgba(255, 105, 135, 0.08);
        transition: all 0.3s ease;
    }

        .data-table-pink tbody tr:last-child {
            border-bottom: none;
        }

        .data-table-pink tbody tr:hover {
            background: linear-gradient(135deg, rgba(255, 105, 135, 0.05) 0%, rgba(255, 179, 193, 0.05) 100%);
            transform: scale(1.01);
        }

    .data-table-pink td {
        padding: 22px 25px;
        font-size: 15px;
        color: #2c2c2c;
    }

    .cell-id {
        font-weight: 600;
    }

    .id-tag-pink {
        display: inline-block;
        padding: 8px 18px;
        background: linear-gradient(135deg, rgba(255, 105, 135, 0.15) 0%, rgba(255, 179, 193, 0.15) 100%);
        color: #ff6987;
        border-radius: 50px;
        font-size: 14px;
        font-weight: 700;
        font-family: 'Courier New', monospace;
        border: 2px solid rgba(255, 105, 135, 0.2);
    }

    .dept-info-pink {
        display: flex;
        align-items: center;
        gap: 15px;
    }

    .dept-icon-pink {
        width: 50px;
        height: 50px;
        border-radius: 50%;
        background: linear-gradient(135deg, #ff6987 0%, #d84a64 100%);
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-size: 22px;
        box-shadow: 0 8px 20px rgba(255, 105, 135, 0.3);
    }

    .dept-name-pink {
        font-weight: 700;
        color: #2c2c2c;
        font-size: 16px;
    }

    .org-tag-pink {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 10px 20px;
        background: linear-gradient(135deg, rgba(102, 126, 234, 0.15) 0%, rgba(118, 75, 162, 0.15) 100%);
        color: #667eea;
        border-radius: 50px;
        font-size: 14px;
        font-weight: 600;
        border: 2px solid rgba(102, 126, 234, 0.2);
    }

        .org-tag-pink i {
            font-size: 16px;
        }

    .cell-actions {
        text-align: center;
    }

    .action-buttons-pink {
        display: flex;
        justify-content: center;
        gap: 12px;
    }

    .btn-action-pink {
        width: 45px;
        height: 45px;
        display: flex;
        align-items: center;
        justify-content: center;
        border: none;
        border-radius: 50%;
        cursor: pointer;
        transition: all 0.3s ease;
        font-size: 16px;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
    }

    .btn-edit-pink {
        background: linear-gradient(135deg, rgba(255, 179, 71, 0.2) 0%, rgba(255, 152, 0, 0.2) 100%);
        color: #ff9800;
        border: 2px solid rgba(255, 152, 0, 0.3);
    }

        .btn-edit-pink:hover {
            background: linear-gradient(135deg, #ffb347 0%, #ff9800 100%);
            color: white;
            transform: translateY(-3px) rotate(360deg);
            box-shadow: 0 8px 25px rgba(255, 152, 0, 0.4);
        }

    .btn-delete-pink {
        background: linear-gradient(135deg, rgba(239, 68, 68, 0.2) 0%, rgba(220, 38, 38, 0.2) 100%);
        color: #dc2626;
        border: 2px solid rgba(220, 38, 38, 0.3);
    }

        .btn-delete-pink:hover {
            background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%);
            color: white;
            transform: translateY(-3px) scale(1.1);
            box-shadow: 0 8px 25px rgba(220, 38, 38, 0.4);
        }

    @@media (max-width: 768px) {
        .departments-container-pink {
            padding: 20px;
            border-radius: 20px;
        }

        .btn-create-pink {
            width: 100%;
            justify-content: center;
            padding: 14px 24px;
        }

        .data-table-pink th,
        .data-table-pink td {
            padding: 15px;
            font-size: 13px;
        }

        .dept-icon-pink {
            width: 40px;
            height: 40px;
            font-size: 18px;
        }

        .btn-action-pink {
            width: 40px;
            height: 40px;
            font-size: 14px;
        }

        .org-tag-pink {
            font-size: 12px;
            padding: 8px 14px;
        }
    }
</style>