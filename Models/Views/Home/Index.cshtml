<script>
    function hideAllSections() {
        document.getElementById("organizations").style.display = "none";
        document.getElementById("departments").style.display = "none";
        document.getElementById("positions").style.display = "none";
        document.getElementById("employees").style.display = "none";

        var dashboardSection = document.getElementById("dashboard");
        if (dashboardSection) {
            dashboardSection.style.display = "block";
            dashboardSection.scrollIntoView({ behavior: 'smooth' });
        }
    }

    document.getElementById("org-card").addEventListener("click", function () {
        hideAllSections();
        document.getElementById("organizations").style.display = "block";
        fetch('/Organization/List')
            .then(res => res.text())
            .then(html => {
                document.getElementById("org-content").innerHTML = html;
            });
        document.getElementById("organizations").scrollIntoView({ behavior: 'smooth' });
    });

    document.getElementById("dept-card").addEventListener("click", function () {
        hideAllSections();
        document.getElementById("departments").style.display = "block";
        fetch('/Department/List')
            .then(res => res.text())
            .then(html => {
                document.getElementById("department-content").innerHTML = html;
            });
        document.getElementById("departments").scrollIntoView({ behavior: 'smooth' });
    });

    function refreshDepartmentTable() {
        fetch('/Department/List')
            .then(res => res.text())
            .then(html => {
                document.getElementById("department-content").innerHTML = html;
            });
    }

    document.getElementById("position-card").addEventListener("click", function () {
        hideAllSections();
        document.getElementById("positions").style.display = "block";
        fetch('/Position/List')
            .then(res => res.text())
            .then(html => {
                document.getElementById("position-content").innerHTML = html;
            });
        document.getElementById("positions").scrollIntoView({ behavior: 'smooth' });
    });

    function refreshPositionTable() {
        fetch('/Position/List')
            .then(res => res.text())
            .then(html => {
                document.getElementById("position-content").innerHTML = html;
            });
    }

    document.getElementById("employee-card").addEventListener("click", function () {
        hideAllSections();
        document.getElementById("employees").style.display = "block";
        fetch('/Employee/List')
            .then(res => res.text())
            .then(html => {
                document.getElementById("employee-content").innerHTML = html;
            });
        document.getElementById("employees").scrollIntoView({ behavior: 'smooth' });
    });

    function refreshEmployeeTable() {
        fetch('/Employee/List')
            .then(res => res.text())
            .then(html => {
                document.getElementById("employee-content").innerHTML = html;
            });
    }

    // AJAX Form Handlers
    $(document).on("submit", "#org-delete-form", function (e) {
        e.preventDefault();
        $.ajax({
            url: '/Organization/DeleteConfirmed',
            type: 'POST',
            data: $(this).serialize(),
            success: function (res) {
                if (res.success) {
                    refreshOrgTable();
                } else {
                    alert("❌ " + res.message);
                }
            }
        });
    });

    $(document).on("submit", "#dept-delete-form", function (e) {
        e.preventDefault();
        $.ajax({
            url: '/Department/Delete',
            type: 'POST',
            data: $(this).serialize(),
            success: function (res) {
                if (res.success) {
                    refreshDepartmentTable();
                } else {
                    alert("❌ " + res.message);
                }
            }
        });
    });

    $(document).on("submit", "#org-create-form", function (e) {
        e.preventDefault();
        $.ajax({
            url: '/Organization/Create',
            type: 'POST',
            data: $(this).serialize(),
            success: function (res) {
                if (res.success) {
                    refreshOrgTable();
                }
            }
        });
    });

    $(document).on("submit", "#dept-create-form", function (e) {
        e.preventDefault();
        $.ajax({
            url: '/Department/Create',
            type: 'POST',
            data: $(this).serialize(),
            success: function (res) {
                if (res.success) {
                    refreshDepartmentTable();
                }
            }
        });
    });

    $(document).on("submit", "#org-edit-form", function (e) {
        e.preventDefault();
        $.ajax({
            url: '/Organization/Edit',
            type: 'POST',
            data: $(this).serialize(),
            success: function (res) {
                if (res.success) {
                    refreshOrgTable();
                }
            }
        });
    });

    $(document).on("submit", "#dept-edit-form", function (e) {
        e.preventDefault();
        $.ajax({
            url: '/Department/Edit',
            type: 'POST',
            data: $(this).serialize(),
            success: function (res) {
                if (res.success) {
                    refreshDepartmentTable();
                }
            }
        });
    });
</script>