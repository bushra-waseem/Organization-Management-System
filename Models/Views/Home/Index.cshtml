@{
    ViewData["Title"] = "Home Page";
}

<style>
    /* HERO SECTION */
    .hero-pink-section {
        min-height: 100vh;
        background: linear-gradient(135deg, #fef5f8 0%, #ffe5ed 50%, #ffd4e3 100%);
        display: flex;
        align-items: center;
        padding: 140px 0 100px;
        position: relative;
        overflow: hidden;
    }


        .hero-pink-section::before {
            content: 'NEW';
            position: absolute;
            top: 20%;
            right: -100px;
            font-size: 300px;
            font-weight: 900;
            color: rgba(255, 105, 135, 0.05);
            transform: rotate(-15deg);
            letter-spacing: 20px;
        }

    .hero-grid-pink {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 80px;
        align-items: center;
        position: relative;
        z-index: 2;
    }

    .hero-badge-pink {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        background: linear-gradient(135deg, #ff6987 0%, #d84a64 100%);
        color: #fff;
        padding: 10px 25px;
        border-radius: 50px;
        font-size: 13px;
        font-weight: 700;
        margin-bottom: 25px;
        box-shadow: 0 8px 25px rgba(255, 105, 135, 0.3);
        animation: bounce 2s infinite;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

   
    .hero-title-pink {
        font-size: 72px;
        font-weight: 900;
        line-height: 1.1;
        color: #2c2c2c;
        margin-bottom: 25px;
        letter-spacing: -3px;
    }

        .hero-title-pink .gradient-text {
            display: block;
            font-size: 90px;
            margin-top: 10px;
            text-shadow: 0 8px 20px rgba(255, 105, 135, 0.3);
        }

        .hero-title-pink .outline-text {
            color: transparent;
            -webkit-text-stroke: 2px #ff6987;
            display: block;
            opacity: 0.3;
            font-size: 60px;
        }

    .hero-description-pink {
        font-size: 18px;
        color: #6a6a6a;
        line-height: 1.8;
        margin-bottom: 40px;
        max-width: 520px;
    }

    .btn-group-pink {
        display: flex;
        gap: 20px;
        margin-bottom: 60px;
    }

    .feature-icons-pink {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 25px;
    }

    .feature-icon-pink {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 12px;
        padding: 20px;
        background: rgba(255, 255, 255, 0.7);
        backdrop-filter: blur(10px);
        border-radius: 20px;
        transition: all 0.3s ease;
        border: 2px solid transparent;
    }

        .feature-icon-pink:hover {
            transform: translateY(-8px);
            background: #fff;
            border-color: rgba(255, 105, 135, 0.3);
            box-shadow: 0 15px 40px rgba(255, 105, 135, 0.2);
        }

    .icon-circle-pink {
        width: 60px;
        height: 60px;
        border-radius: 50%;
        background: linear-gradient(135deg, #ff6987 0%, #d84a64 100%);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 28px;
        color: #fff;
        box-shadow: 0 10px 30px rgba(255, 105, 135, 0.3);
    }

    .feature-icon-pink span {
        font-size: 14px;
        color: #2c2c2c;
        font-weight: 600;
    }

    .hero-image-pink {
        position: relative;
      
        z-index: 1;
        width: 100%;
        max-width: none !important;
    }
    

    .hero-main-image {
        width: 650px !important; /* force size */
        max-width: none !important;
        border-radius: 40px;
       animation: smooth-circle-rotate 20s linear infinite;

        position: relative;
        z-index: 2;
        
    }
    @@keyframes smooth-circle-rotate {
        from {
            transform: rotate(0deg);
        }

        to {
            transform: rotate(360deg);
        }
    }

        .hero-main-image:hover {
            
        }

    .floating-badge-pink {
        position: absolute;
        background: #fff;
        padding: 20px 30px;
        border-radius: 25px;
        box-shadow: 0 15px 40px rgba(255, 105, 135, 0.3);
        display: flex;
        align-items: center;
        z-index: 5;
        gap: 15px;
        font-weight: 700;
        font-size: 16px;
        animation: fast-float 1s ease-in-out infinite alternate;
        border: 3px solid rgba(255, 105, 135, 0.2);
        transform: translateY(0);
    }

    @@keyframes fast-float {
        from {
            transform: translateY(0);
        }

        to {
            transform: translateY(-10px);
        }
    }


    
    .badge-pink-1 {
        top: 0%;
        left: -60px;
        animation-delay: 0.5s;
    }

    .badge-pink-2 {
        bottom: 8%;
        right: -90px;
        animation-delay: 1s;
    }

    .floating-badge-pink i {
        font-size: 28px;
        color: #ff6987;
    }

    .floating-badge-pink .badge-number {
        font-size: 28px;
        font-weight: 900;
        background: linear-gradient(135deg, #ff6987 0%, #d84a64 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    /* ABOUT SECTION */
    .about-pink-section {
        padding: 120px 0;
        background: #fff;
        position: relative;
        overflow: hidden;
    }

        .about-pink-section::before {
            content: 'ABOUT';
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            font-size: 200px;
            font-weight: 900;
            color: rgba(255, 105, 135, 0.03);
            letter-spacing: 20px;
        }

    .about-grid-pink {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 100px;
        align-items: center;
        position: relative;
        z-index: 2;
    }

    .about-image-wrapper {
        position: relative;
    }

        .about-image-wrapper img {
            width: 100%;
            border-radius: 40px;
            box-shadow: 0 30px 80px rgba(255, 105, 135, 0.25);
            position: relative;
            z-index: 2;
        }
    .social-modern {
        display: flex;
        gap: 15px;
    }

        .social-modern a {
            width: 45px;
            height: 45px;
            border-radius: 50%;
            
            display: flex;
            align-items: center;
            justify-content: center;
            
            font-size: 18px;
            text-decoration: none;
            transition: all 0.3s ease;
        }

            .social-modern a:hover {
                
                transform: translateY(-3px);
            }


    .decorative-circle-pink {
        position: absolute;
        border-radius: 50%;
        z-index: 1;
    }

    .circle-pink-1 {
        width: 200px;
        height: 200px;
        background: linear-gradient(135deg, rgba(255, 105, 135, 0.2) 0%, rgba(255, 179, 193, 0.2) 100%);
        top: -40px;
        left: -40px;
        animation: rotate 10s linear infinite;
    }

    .circle-pink-2 {
        width: 150px;
        height: 150px;
        background: linear-gradient(135deg, rgba(216, 74, 100, 0.2) 0%, rgba(255, 105, 135, 0.2) 100%);
        bottom: -30px;
        right: -30px;
        animation: rotate 8s linear infinite reverse;
    }
    @@keyframes rotate {
        from {
            transform: rotate(0deg);
        }

        to {
            transform: rotate(360deg);
        }
    }

    .section-badge-pink {
        display: inline-block;
        background: linear-gradient(135deg, rgba(255, 105, 135, 0.15) 0%, rgba(255, 179, 193, 0.15) 100%);
        color: #ff6987;
        padding: 10px 25px;
        border-radius: 50px;
        font-size: 14px;
        font-weight: 700;
        margin-bottom: 20px;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .section-title-pink {
        font-size: 56px;
        font-weight: 900;
        line-height: 1.2;
        color: #2c2c2c;
        margin-bottom: 25px;
        letter-spacing: -2px;
    }

    .section-description-pink {
        font-size: 17px;
        color: #6a6a6a;
        line-height: 1.8;
        margin-bottom: 20px;
    }

    .stats-row-pink {
        display: flex;
        gap: 50px;
        margin: 40px 0;
    }

    .stat-item-pink {
        position: relative;
        padding-left: 20px;
    }

        .stat-item-pink::before {
            content: '';
            position: absolute;
            left: 0;
            top: 0;
            bottom: 0;
            width: 5px;
            background: linear-gradient(180deg, #ff6987 0%, #d84a64 100%);
            border-radius: 10px;
        }

        .stat-item-pink h3 {
            font-size: 48px;
            font-weight: 900;
            background: linear-gradient(135deg, #ff6987 0%, #d84a64 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            margin-bottom: 8px;
        }

        .stat-item-pink p {
            font-size: 15px;
            color: #6a6a6a;
            font-weight: 600;
        }

    /* DASHBOARD SECTION */
    .dashboard-pink-section {
        padding: 120px 0;
        background: linear-gradient(135deg, #fef5f8 0%, #ffe5ed 100%);
        position: relative;
    }

    .section-header-center-pink {
        text-align: center;
        margin-bottom: 80px;
    }

    .section-subtitle-pink {
        font-size: 18px;
        color: #6a6a6a;
        margin-top: 15px;
        max-width: 600px;
        margin-left: auto;
        margin-right: auto;
    }

    .dashboard-grid-pink {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: 35px;
    }

    .dashboard-card-pink {
        background: #fff;
        border-radius: 35px;
        padding: 45px 35px;
        box-shadow: 0 15px 50px rgba(255, 105, 135, 0.15);
        transition: all 0.4s ease;
        cursor: pointer;
        border: 3px solid transparent;
        position: relative;
        overflow: hidden;
    }

        .dashboard-card-pink::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 6px;
            background: linear-gradient(90deg, #ff6987, #d84a64);
            transform: scaleX(0);
            transform-origin: left;
            transition: transform 0.4s ease;
        }

        .dashboard-card-pink:hover::before {
            transform: scaleX(1);
        }

        .dashboard-card-pink:hover {
            transform: translateY(-15px) scale(1.03);
            box-shadow: 0 25px 70px rgba(255, 105, 135, 0.25);
            border-color: rgba(255, 105, 135, 0.3);
        }

    .card-icon-pink {
        width: 80px;
        height: 80px;
        border-radius: 25px;
        background: linear-gradient(135deg, #ff6987 0%, #d84a64 100%);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 38px;
        color: #fff;
        margin-bottom: 30px;
        box-shadow: 0 15px 40px rgba(255, 105, 135, 0.4);
        transition: all 0.3s ease;
    }

    .dashboard-card-pink:hover .card-icon-pink {
        transform: rotate(360deg) scale(1.1);
    }

    .dashboard-card-pink h3 {
        font-size: 28px;
        font-weight: 800;
        color: #2c2c2c;
        margin-bottom: 15px;
    }

    .dashboard-card-pink p {
        font-size: 16px;
        color: #6a6a6a;
        margin-bottom: 25px;
        line-height: 1.6;
    }

    .card-footer-pink {
        display: flex;
        justify-content: flex-end;
    }

    .card-link-pink {
        color: #ff6987;
        font-weight: 700;
        font-size: 16px;
        display: flex;
        align-items: center;
        gap: 8px;
        transition: all 0.3s ease;
    }

    .dashboard-card-pink:hover .card-link-pink {
        gap: 15px;
    }

    /* MANAGEMENT SECTIONS */
    .management-section-pink {
        padding: 100px 0;
        background: #fff;
    }

    .management-card-pink {
        background: #fff;
        border-radius: 40px;
        padding: 50px;
        box-shadow: 0 20px 60px rgba(255, 105, 135, 0.15);
        border: 3px solid rgba(255, 105, 135, 0.1);
    }

    .management-header-pink {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 40px;
        padding-bottom: 25px;
        border-bottom: 3px solid rgba(255, 105, 135, 0.1);
    }

    .management-title-pink {
        font-size: 40px;
        font-weight: 900;
        background: linear-gradient(135deg, #ff6987 0%, #d84a64 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        margin-bottom: 8px;
    }

    .management-subtitle-pink {
        font-size: 16px;
        color: #6a6a6a;
    }

    .btn-back-pink {
        background: linear-gradient(135deg, rgba(255, 105, 135, 0.15) 0%, rgba(255, 179, 193, 0.15) 100%);
        color: #ff6987;
        padding: 14px 28px;
        border-radius: 25px;
        border: none;
        font-weight: 700;
        cursor: pointer;
        transition: all 0.3s ease;
        display: flex;
        align-items: center;
        gap: 10px;
    }

        .btn-back-pink:hover {
            background: linear-gradient(135deg, #ff6987 0%, #d84a64 100%);
            color: #fff;
            transform: translateX(-5px);
        }

    /* CTA SECTION */
    .cta-section-pink {
        padding: 120px 0;
        background: linear-gradient(135deg, #d84a64 0%, #a83750 100%);
        text-align: center;
        color: #fff;
        position: relative;
        overflow: hidden;
    }

        .cta-section-pink::before {
            content: 'START';
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            font-size: 250px;
            font-weight: 900;
            color: rgba(255, 255, 255, 0.05);
            letter-spacing: 30px;
        }

    .cta-content-pink {
        position: relative;
        z-index: 2;
    }

        .cta-content-pink h2 {
            font-size: 60px;
            font-weight: 900;
            margin-bottom: 25px;
            line-height: 1.2;
            text-shadow: 0 4px 15px rgba(0, 0, 0, 0.2);
        }

        .cta-content-pink p {
            font-size: 20px;
            opacity: 0.95;
            max-width: 750px;
            margin: 0 auto 50px;
            line-height: 1.7;
        }

    .btn-cta-pink {
        background: #fff;
        color: #ff6987;
        padding: 20px 50px;
        border-radius: 50px;
        text-decoration: none;
        font-weight: 900;
        display: inline-block;
        transition: all 0.3s ease;
        box-shadow: 0 15px 40px rgba(0, 0, 0, 0.2);
        font-size: 18px;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

        .btn-cta-pink:hover {
            transform: translateY(-5px);
            box-shadow: 0 20px 50px rgba(0, 0, 0, 0.3);
            background: #ffc4d0;
        }

    /* RESPONSIVE */
    @@media (max-width: 768px) {
        .hero-grid-pink,
        .about-grid-pink {
            grid-template-columns: 1fr;
            gap: 50px;
        }

        .hero-title-pink {
            font-size: 48px;
        }

            .hero-title-pink .gradient-text {
                font-size: 56px;
            }

        .feature-icons-pink {
            grid-template-columns: repeat(2, 1fr);
        }

        .dashboard-grid-pink {
            grid-template-columns: 1fr;
        }
    }

</style>

<!-- ================= HERO SECTION ================= -->
<section id="home" class="hero-pink-section">
    <div class="container">
        <div class="hero-grid-pink">
            <div class="hero-content-left">
                <div class="hero-badge-pink">
                    <i class="bi bi-star-fill"></i>
                    Best Management Solution
                </div>
                <h1 class="hero-title-pink">
                    Manage Everything
                    <span class="gradient-text">Effortlessly</span>
                    <span class="outline-text">MODERN</span>
                </h1>
                <p class="hero-description-pink">
                    A stunning modern management system to organize organizations, departments,
                    positions and employees with an intuitive and beautiful interface.
                </p>
                <div class="btn-group-pink">
                    <a href="#dashboard" class="btn-pink-modern">Get Started</a>
                    <a href="#about" class="btn-outline-pink">Learn More</a>
                </div>

                <div class="feature-icons-pink">
                    <div class="feature-icon-pink">
                        <div class="icon-circle-pink"><i class="bi bi-building"></i></div>
                        <span>Organizations</span>
                    </div>
                    <div class="feature-icon-pink">
                        <div class="icon-circle-pink"><i class="bi bi-diagram-3"></i></div>
                        <span>Departments</span>
                    </div>
                    <div class="feature-icon-pink">
                        <div class="icon-circle-pink"><i class="bi bi-people"></i></div>
                        <span>Employees</span>
                    </div>
                    <div class="feature-icon-pink">
                        <div class="icon-circle-pink"><i class="bi bi-award"></i></div>
                        <span>Positions</span>
                    </div>
                </div>
            </div>

            <div class="hero-image-pink">
                <img src="~/images/teamwork4.png" class="hero-main-image" alt="Team Work" />

                <div class="floating-badge-pink badge-pink-1">
                    <i class="bi bi-graph-up-arrow"></i>
                    <div class="badge-number">98%</div>
                    <div style="font-size: 12px; color: #6a6a6a;">Success Rate</div>
                </div>
            </div>
            <div class="floating-badge-pink badge-pink-2">
                <i class="bi bi-people-fill"></i>
                <div>
                    <div class="badge-number">500+</div>
                    <div style="font-size: 12px; color: #6a6a6a;">Teams</div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ================= CTA SECTION ================= -->
<section class="cta-section-pink">
    <div class="container">
        <div class="cta-content-pink">
            <h2>Everything Your Team Needs<br>to Work Smarter</h2>
            <p>
                From managing organizations to handling employees in real-time,
                our platform is built to keep your team organized, connected,
                and moving forward together.
            </p>
           
        </div>
    </div>
</section>

<!-- ================= ABOUT SECTION ================= -->
<section id="about" class="about-pink-section">
    <div class="container">
        <div class="about-grid-pink">
            <div class="about-image-wrapper">
                <img src="~/images/about1.png" alt="About Us" />
                <div class="decorative-circle-pink circle-pink-1"></div>
                <div class="decorative-circle-pink circle-pink-2"></div>
            </div>

            <div class="about-content-side">
                <div class="section-badge-pink">About Us</div>
                <h2 class="section-title-pink">
                    Simplify Your<br>
                    Business Operations
                </h2>
                <p class="section-description-pink">
                    OMS (Organization Management System) is designed to simplify and organize
                    your business operations. We help companies manage their departments,
                    positions, and employees with ease.
                </p>
                <p class="section-description-pink">
                    Our intuitive platform brings everything together in one place, making
                    it easier than ever to keep your team organized and productive.
                </p>

                <div class="stats-row-pink">
                    <div class="stat-item-pink">
                        <h3>500+</h3>
                        <p>Active Users</p>
                    </div>
                    <div class="stat-item-pink">
                        <h3>98%</h3>
                        <p>Satisfaction</p>
                    </div>
                    <div class="stat-item-pink">
                        <h3>24/7</h3>
                        <p>Support</p>
                    </div>
                </div>

                <div class="social-modern">
                    <a href="#" style="background: linear-gradient(135deg, rgba(255, 105, 135, 0.15), rgba(255, 179, 193, 0.15)); color: #ff6987;">
                        <i class="bi bi-facebook"></i>
                    </a>
                    <a href="#" style="background: linear-gradient(135deg, rgba(255, 105, 135, 0.15), rgba(255, 179, 193, 0.15)); color: #ff6987;">
                        <i class="bi bi-instagram"></i>
                    </a>
                    <a href="#" style="background: linear-gradient(135deg, rgba(255, 105, 135, 0.15), rgba(255, 179, 193, 0.15)); color: #ff6987;">
                        <i class="bi bi-linkedin"></i>
                    </a>
                    <a href="#" style="background: linear-gradient(135deg, rgba(255, 105, 135, 0.15), rgba(255, 179, 193, 0.15)); color: #ff6987;">
                        <i class="bi bi-github"></i>
                    </a>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ================= DASHBOARD CARDS ================= -->
<section id="dashboard" class="dashboard-pink-section">
    <div class="container">
        <div class="section-header-center-pink">
            <div class="section-badge-pink">Dashboard</div>
            <h2 class="section-title-pink">Manage Your Resources</h2>
            <p class="section-subtitle-pink">Everything you need to run your organization efficiently in one beautiful place</p>
        </div>

        <div class="dashboard-grid-pink">
            <div class="dashboard-card-pink" id="org-card">
                <div class="card-icon-pink">
                    <i class="bi bi-building"></i>
                </div>
                <h3>Organizations</h3>
                <p>Manage and organize your company structure with powerful tools</p>
                <div class="card-footer-pink">
                    <span class="card-link-pink">Manage <i class="bi bi-arrow-right"></i></span>
                </div>
            </div>

            <div class="dashboard-card-pink" id="dept-card">
                <div class="card-icon-pink">
                    <i class="bi bi-diagram-3"></i>
                </div>
                <h3>Departments</h3>
                <p>Organize departments and their hierarchies seamlessly</p>
                <div class="card-footer-pink">
                    <span class="card-link-pink">Manage <i class="bi bi-arrow-right"></i></span>
                </div>
            </div>

            <div class="dashboard-card-pink" id="position-card">
                <div class="card-icon-pink">
                    <i class="bi bi-award"></i>
                </div>
                <h3>Positions</h3>
                <p>Define roles and responsibilities clearly and efficiently</p>
                <div class="card-footer-pink">
                    <span class="card-link-pink">Manage <i class="bi bi-arrow-right"></i></span>
                </div>
            </div>

            <div class="dashboard-card-pink" id="employee-card">
                <div class="card-icon-pink">
                    <i class="bi bi-people"></i>
                </div>
                <h3>Employees</h3>
                <p>Manage your team members with complete control</p>
                <div class="card-footer-pink">
                    <span class="card-link-pink">Manage <i class="bi bi-arrow-right"></i></span>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ================= MANAGEMENT SECTIONS ================= -->
<section id="organizations" style="padding:80px 0; display:none; background:#fef5f8;">
    <div class="container">
        <div class="management-card-pink">
            <div class="management-header-pink">
                <div>
                    <h1 class="management-title-pink">Organizations</h1>
                    <p class="management-subtitle-pink">Manage all organizations from one place</p>
                </div>
                <button class="btn-back-pink" onclick="hideAllSections()">
                    <i class="bi bi-arrow-left"></i> Back to Dashboard
