@{
    ViewData["Title"] = "About Us";
}
<!-- ⭐ Add this wrapper div -->
<div id="about">
<div class="about-section">

    <div class="about-left">
        <img src="~/images/about1.png" alt="Team Image" />
    </div>
    <style>
        .about-left img {
            width: 330px; /* Pehle 330px tha – ab bada */
            height: 330px; /* Round shape maintain hoga */
            object-fit: cover;
            border-radius: 50%;
        }
    </style>

    <div class="about-right">

        <h2>ABOUT US</h2>
        <div class="underline"></div>

        <p>
            OMS (Organization Management System) is designed to simplify and organize
            your business operations. Our mission is to help companies manage their
            departments, positions, and employees with ease using a clean and modern UI.
        </p>

        <p>
            We focus on providing a seamless platform where organizations can stay
            structured, efficient, and productive.
        </p>

        <!-- ⬇ Correct Position for Icons -->
        <div class="social-icons">
            <a href="#"><i class="bi bi-facebook"></i></a>
            <a href="#"><i class="bi bi-instagram"></i></a>
            <a href="#"><i class="bi bi-linkedin"></i></a>
            <a href="#"><i class="bi bi-github"></i></a>
        </div>
        <!-- ⬆⬆ END -->
    </div>

</div> 
</div> <!-- ⭐ This closes the about section -->